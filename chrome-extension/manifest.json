{
  "manifest_version": 3,

  "name": "CommentSense",
  "short_name": "CommentSense",

  "description": "AI-powered YouTube Audience Intelligence.",

  "version": "2.0.0",

  "icons": {
    "128": "assets/icon.png"
  },

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://*.youtube.com/*",
    "https://*.hf.space/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "css": [
        "content/toolbar.css",
           "content/ui.css"
      ],
      "js": [
        "content/utils.js",
        "content/cache.js",
        "content/analyzer.js",
        "content/toolbar.js",
        "content/filters.js",
        "content/ui.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "CommentSense"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "assets/*"
      ],
      "matches": [
        "https://www.youtube.com/*"
      ]
    }
  ]
}